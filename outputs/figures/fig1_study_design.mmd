%% Figure 1 - Study design schematic (held-out analysis pipeline).
%% The thesis is encoded in the Step-3 topology: a purple probe-training
%% lineage (Shenzhen+Montgomery) and a green held-out conformal-calibration
%% lineage (TBX11K development) run as separate siblings and converge only at
%% threshold computation - i.e. the conformal calibration data are independent
%% of probe training. No deployment coverage guarantee is asserted.
%% Render PNG: mmdc -i fig1_study_design.mmd -o fig1_study_design.png -s 3 -b white
%% Render PDF: mmdc -i fig1_study_design.mmd -o fig1_study_design.pdf -b white --pdfFit
flowchart TD

  subgraph S1["<b><span style='font-size:21px'>STEP 1 &nbsp;&middot;&nbsp; Public CXR datasets &nbsp;(N = 20,509)</span></b>"]
    direction LR
    SZ["Shenzhen<br/>n = 662"]
    MG["Montgomery<br/>n = 138"]
    TBX["TBX11K<br/>n = 11,701"]
    PAK["Mendeley Pakistan<br/>n = 3,008"]
    CHX["CheXpert<br/>n = 5,000"]
  end

  subgraph S2["<b><span style='font-size:21px'>STEP 2 &nbsp;&middot;&nbsp; Frozen foundation-model embeddings</span></b>"]
    EMB["Weights frozen &mdash; no fine-tuning<br/>RAD-DINO 768-d (primary)<br/>BiomedCLIP 512-d<br/>torchxrayvision 1024-d<br/>DINOv2-B 768-d (non-medical control)"]
  end

  subgraph S3["<b><span style='font-size:21px'>STEP 3 &nbsp;&middot;&nbsp; Probe training &amp; held-out conformal calibration</span></b>"]
    direction LR
    PT["<b>Probe-training lineage</b><br/>Shenzhen + Montgomery (n = 800)<br/>Linear (primary), k-NN, XGBoost, MLP"]
    DEVCAL["<b>Held-out conformal-calibration lineage</b><br/>TBX11K development split (n = 2,520)<br/><i>different images; never used to train the probe</i><br/>50/50 &rarr; isotonic recal (1,260) + conformal cal (1,260)"]
    CONF["<b>Mondrian class-conditional thresholds</b><br/>+ isotonic probability recalibration<br/>(APS for comparison), &alpha; = 0.10"]
  end

  subgraph S4["<b><span style='font-size:21px'>STEP 4 &nbsp;&middot;&nbsp; Prediction sets &amp; three-tier triage</span></b>"]
    direction LR
    T1["<b>Tier 1 &mdash; CLEAR</b><br/>set = {non-TB}<br/>discharge"]
    SETS["<b>Prediction sets</b><br/>applied to TBX11K test (n = 5,879)<br/>+ Pakistan (n = 3,008)<br/>+ CheXpert distractor"]
    T2["<b>Tier 2 &mdash; REFER</b><br/>set = {TB}<br/>Xpert MTB/RIF"]
    T3["<b>Tier 3 &mdash; UNCERTAIN</b><br/>set = {TB, non-TB}<br/>clinical review"]
  end

  NOTE["WHO Type 2 TPP rule (sens &ge; 90% / spec &ge; 70%) is reported as a worked example &mdash; not asserted as met in deployment.<br/>Conformal validity is a property of the calibration distribution, conditional on exchangeability."]

  SZ --> EMB
  MG --> EMB
  TBX --> EMB
  PAK --> EMB
  CHX --> EMB

  EMB --> PT
  EMB --> DEVCAL
  PT -->|"fitted probe"| CONF
  DEVCAL -->|"held-out scores"| CONF
  CONF --> SETS
  SETS --> T1
  SETS --> T2
  SETS --> T3
  T1 --> NOTE
  T2 --> NOTE
  T3 --> NOTE

