  classDef output fill:#fcefd2,stroke:#d99a1c,stroke-width:1.6px,color:#6b4a00;
  classDef tier1 fill:#cdeccd,stroke:#28a745,stroke-width:1.6px,color:#114a1c;
  classDef tier2 fill:#f7cdd2,stroke:#dc3545,stroke-width:1.6px,color:#69121c;
  classDef tier3 fill:#fdeeb3,stroke:#e0a800,stroke-width:1.6px,color:#6b5200;
  classDef note fill:#fbf6ec,stroke:#b9923a,stroke-width:1.2px,color:#5c4708;

  class SZ,MG,TBX,PAK,CHX source;
